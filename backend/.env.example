# ============================================================
# Research Paper Analyzer - Environment Variables
# Copy this file to .env and fill in your keys
# ============================================================

# ── LLM PROVIDER ─────────────────────────────────────────────
# Options: "groq" (FREE) or "openai" (paid)
LLM_PROVIDER=groq

# ── GROQ (FREE) ───────────────────────────────────────────────
# Get your FREE key at: https://console.groq.com
# Free tier: 14,400 requests/day — more than enough!
GROQ_API_KEY=gsk_your_groq_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# ── OPENAI (Optional, only if LLM_PROVIDER=openai) ───────────
# Only needed if you prefer OpenAI over Groq
OPENAI_API_KEY=sk-your-openai-key-here

# ── EMBEDDINGS ────────────────────────────────────────────────
# Options: "local" (FREE, runs on CPU) or "openai" (paid)
EMBEDDING_PROVIDER=local
LOCAL_EMBEDDING_MODEL=all-MiniLM-L6-v2

# ── Semantic Scholar (Optional) ───────────────────────────────
# Free key at: https://www.semanticscholar.org/product/api
# Without key it still works, just lower rate limits
SEMANTIC_SCHOLAR_API_KEY=

# ── App Settings ──────────────────────────────────────────────
MAX_PAPERS=8
CHROMA_PERSIST_DIR=./data/chroma_db
PAPERS_DIR=./data/papers
LOG_LEVEL=INFO

# ── FastAPI ───────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000

# ── Frontend ──────────────────────────────────────────────────
API_BASE_URL=http://localhost:8000
